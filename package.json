{
	"name": "all-or-nothing-game",
	"version": "1.14.2",
	"type": "module",
	"main": "dist-electron/main.js",
	"browserslist": "chrome > 140",
	"scripts": {
		"dev": "vite",
		"dev:electron": "cross-env BUILD_TARGET=electron vite",
		"preview": "vite preview",
		"typecheck": "tsc --noEmit && tsc -p electron/tsconfig.json",
		"build": "tsc --noEmit && vite build",
		"build:electron": "tsc -p electron/tsconfig.json && cross-env BUILD_TARGET=electron vite build",
		"package:electron:linux": "electron-builder --linux --config electron-builder.config.ts",
		"package:electron:windows": "electron-builder --win --config electron-builder.config.ts"
	},
	"author": "",
	"license": "ISC",
	"description": "",
	"dependencies": {
		"steamworks.js": "^0.4.0"
	},
